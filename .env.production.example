# Production environment — copy to .env.production and fill in ALL values.
# Run: task env:sync:production   (pushes to GitHub Actions via gh CLI)
# Never commit .env.production to git.

# ── Server ────────────────────────────────────────────────────────────────────
ENV=production
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# postgres runs in Docker on the VPS — replace CHANGEME with a strong password.
# This same password must match POSTGRES_PASSWORD in docker-compose.prod.yml env vars.
DATABASE_URL=postgres://retainr:CHANGEME@localhost:5432/retainr?sslmode=require

# ── Voyage AI ─────────────────────────────────────────────────────────────────
VOYAGE_API_KEY=

# ── Stripe (LIVE keys — never put in dev) ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@retainr.dev

# ── Scaleway Object Storage ───────────────────────────────────────────────────
# IAM API key with ObjectStorageObjectsWrite + Read on bucket "retainr-pdfs"
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_BUCKET=retainr-pdfs
SCW_ENDPOINT=https://s3.fr-par.scw.cloud
SCW_REGION=fr-par

# ── Umami analytics ───────────────────────────────────────────────────────────
UMAMI_DB_PASSWORD=
UMAMI_APP_SECRET=

# ── Docker Compose (postgres service) ─────────────────────────────────────────
# Must match the password in DATABASE_URL above
POSTGRES_USER=retainr
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=retainr

# ── Dokploy deploy webhooks ───────────────────────────────────────────────────
# Get these from Dokploy UI → each app → Deployments tab → Webhook URL
# DOKPLOY_PRODUCTION_WEBHOOK and DOKPLOY_STAGING_WEBHOOK go in GitHub Actions secrets.
# DOKPLOY_PRODUCTION_ROLLBACK_WEBHOOK: in Dokploy → app → Advanced → Rollback webhook
DOKPLOY_PRODUCTION_WEBHOOK=
DOKPLOY_PRODUCTION_ROLLBACK_WEBHOOK=
DOKPLOY_STAGING_WEBHOOK=

# ── Claude Code (GitHub Actions) ─────────────────────────────────────────────
# Used by .github/workflows/claude.yml, investigate.yml, security-audit.yml
# Get key at: https://console.anthropic.com/api-keys
# This goes into GitHub Actions secrets (not the VPS) — set via: task env:sync:production
ANTHROPIC_API_KEY=

# ── VPS → GitHub dispatch token ───────────────────────────────────────────────
# PAT with 'repo' scope — used by health-check.sh to trigger repository_dispatch
# when the API is down and service restart doesn't help.
# Create at: https://github.com/settings/tokens (classic) → repo scope
# This IS stored on the VPS in /opt/retainr/.env (not in GitHub Actions)
GITHUB_DISPATCH_TOKEN=
GITHUB_REPO=your-github-username/money-making-experiment

# ── VPS SSH (used by GitHub Actions deploy job) ───────────────────────────────
# IP from: terraform output server_ip
VPS_HOST=
VPS_USER=retainr
# Private key — paste full contents of ~/.ssh/id_ed25519 (the PRIVATE key, not .pub)
# Tip: cat ~/.ssh/id_ed25519 | pbcopy (macOS) or xclip -sel clip (Linux)
VPS_SSH_KEY=
# Host key — run: ssh-keyscan <VPS_HOST> 2>/dev/null | head -3
VPS_HOST_KEY=
