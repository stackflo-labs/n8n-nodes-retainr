{
  "name": "@retainr/n8n-nodes-retainr",
  "version": "0.1.0",
  "description": "n8n community node for retainr.dev — persistent AI agent memory for automation workflows",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ai",
    "memory",
    "agent",
    "automation"
  ],
  "license": "MIT",
  "homepage": "https://retainr.dev",
  "author": "retainr.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/retainr/retainr"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "pnpm build"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RetainrApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Retainr/Retainr.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "n8n-workflow": "*",
    "typescript": "^5.0.0"
  }
}
