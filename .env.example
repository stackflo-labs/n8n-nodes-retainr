# Copy to .env and fill in values. Never commit .env to git.

# Server
ENV=development
PORT=8080

# Database (local dev: use docker-compose.dev.yml)
DATABASE_URL=postgres://retainr:retainr@localhost:5432/retainr_dev?sslmode=disable

# Voyage AI — get key at https://www.voyageai.com
VOYAGE_API_KEY=

# Stripe — use test keys in dev
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Resend — get key at https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@retainr.dev

# Hetzner Object Storage (for PDF files) — optional in dev
HETZNER_OS_ACCESS_KEY=
HETZNER_OS_SECRET_KEY=
HETZNER_OS_BUCKET=retainr-pdfs
HETZNER_OS_ENDPOINT=https://fsn1.your-objectstorage.com
