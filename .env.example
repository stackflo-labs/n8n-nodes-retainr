# Copy to .env — never commit .env
# Dev values are safe defaults; production values live in .env.production

# ── Server ────────────────────────────────────────────────────────────────────
ENV=development
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: docker compose -f infra/docker-compose.dev.yml up -d
DATABASE_URL=postgres://retainr:retainr@localhost:5432/retainr_dev?sslmode=disable

# ── Voyage AI ─────────────────────────────────────────────────────────────────
# https://www.voyageai.com → API Keys
VOYAGE_API_KEY=

# ── Stripe (use TEST keys in dev) ─────────────────────────────────────────────
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_
# https://dashboard.stripe.com/test/webhooks → stripe listen --forward-to localhost:8080/v1/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_

# ── Resend ────────────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@retainr.dev

# ── Scaleway Object Storage (for PDF files) ───────────────────────────────────
# https://console.scaleway.com/object-storage → create bucket "retainr-pdfs-dev"
# IAM API key needs: ObjectStorageObjectsWrite + ObjectStorageObjectsRead
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_BUCKET=retainr-pdfs-dev
SCW_ENDPOINT=https://s3.fr-par.scw.cloud
SCW_REGION=fr-par

# ── Umami analytics (local dev at http://localhost:3001) ──────────────────────
# docker compose -f infra/docker-compose.dev.yml up -d includes umami
UMAMI_DB_PASSWORD=umami
UMAMI_APP_SECRET=dev-secret-change-in-prod
