# Staging environment — copy to .env.staging and fill in.
# Run: task env:sync:staging   (pushes to GitHub Actions 'staging' environment)
# Never commit .env.staging to git.
#
# Staging uses STRIPE TEST keys and a separate Scaleway Object Storage bucket.
# The staging database (retainr_staging) is isolated from production.

# ── Server ────────────────────────────────────────────────────────────────────
ENV=staging
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
# Separate database from production — Dokploy manages separate postgres container
DATABASE_URL=postgres://retainr:CHANGEME@localhost:5432/retainr_staging?sslmode=require

# ── Voyage AI ─────────────────────────────────────────────────────────────────
# Can share the same key as production (embeddings are cheap and stateless)
VOYAGE_API_KEY=

# ── Stripe (TEST keys only — NEVER use live keys in staging) ──────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=staging@retainr.dev

# ── Scaleway Object Storage (separate staging bucket) ─────────────────────────
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_BUCKET=retainr-pdfs-staging
SCW_ENDPOINT=https://s3.fr-par.scw.cloud
SCW_REGION=fr-par

# ── Docker Compose (postgres service) ─────────────────────────────────────────
POSTGRES_USER=retainr
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=retainr_staging

# ── Claude Code (GitHub Actions — same key as production is fine) ─────────────
ANTHROPIC_API_KEY=

# ── Dokploy staging deploy webhook ───────────────────────────────────────────
# Get from: Dokploy UI → staging compose app → Deployments → Webhook URL
# Used by GitHub Actions to trigger Dokploy staging deploys
DOKPLOY_STAGING_WEBHOOK=

# ── GitHub dispatch token (VPS → GitHub) ──────────────────────────────────────
# Same PAT as production — used by health-check.sh
GITHUB_DISPATCH_TOKEN=
GITHUB_REPO=your-github-username/money-making-experiment
