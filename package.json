{
  "name": "@stackflo-labs/n8n-nodes-retainr",
  "version": "0.2.4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stackflo-labs/n8n-nodes-retainr.git"
  },
  "description": "n8n community node for retainr.dev — AI agent memory persistence API. Store, search, and retrieve semantic memories for AI agents across workflow runs.",
  "license": "MIT",
  "author": {
    "name": "stackflo-labs",
    "email": "sebastian.stupak@pm.me",
    "url": "https://retainr.dev"
  },
  "homepage": "https://github.com/stackflo-labs/n8n-nodes-retainr",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RetainrApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Retainr/Retainr.node.js"
    ]
  },
  "main": "dist/nodes/Retainr/Retainr.node.js",
  "files": [
    "dist/credentials",
    "dist/nodes/Retainr/Retainr.node.js",
    "dist/nodes/Retainr/Retainr.node.d.ts",
    "dist/nodes/Retainr/retainr.svg"
  ],
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/**/*.svg\" dist",
    "lint": "npx @n8n/scan-community-package @stackflo-labs/n8n-nodes-retainr",
    "clean": "rimraf dist",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "e2e": "node e2e/integration-test.mjs",
    "e2e:up": "docker compose -f e2e/docker-compose.yml up --build -d",
    "e2e:down": "docker compose -f e2e/docker-compose.yml down",
    "e2e:run": "npm run e2e:up && npm run e2e -- && npm run e2e:down"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "retainr",
    "ai-memory",
    "agent-memory",
    "vector-search",
    "semantic-memory",
    "llm",
    "ai-agent"
  ],
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "copyfiles": "^2.4.1",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.70.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.7.0"
  }
}
